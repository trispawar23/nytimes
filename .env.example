# -----------------------------------------------------------------------------
# Next.js does NOT load this file. Copy variables into:
#   - `.env.local` for `npm run dev` and most local runs
#   - `.env.production.local` for `npm run start` (production mode on your machine)
#   - Or set them in your host dashboard (e.g. Vercel → Settings → Environment Variables)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# Optional: OpenAI text-to-speech for the article listen buttons.
# Defaults: OPENAI_TTS_MODEL=gpt-4o-mini-tts, OPENAI_TTS_VOICE=coral, and OPENAI_TTS_FORMAT=aac.
# Good voice options for news reading include coral, marin, cedar, sage, and alloy.
# Good mobile/PWA formats include aac. For lowest generation latency, try wav.
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=coral
# OPENAI_TTS_FORMAT=aac

# --- Live headlines (first match wins) ---
#
# This demo limits the feed and full-text fetch allowlist to Fox News (`foxnews.com`) only.

# SerpAPI (https://serpapi.com) — recommended. Server calls GET https://serpapi.com/search.json
# (same as the Ruby `serpapi` gem). Never commit your real key.
SERPAPI_API_KEY=

# Engine: google_news (default) or google — https://serpapi.com/search-api
# SERPAPI_ENGINE=google_news

# Single-query mode (optional): overrides the multi-query blend, e.g. Coffee + Austin below.
# SERPAPI_Q=Coffee

# Optional Google Search localization (when SERPAPI_ENGINE=google), mirrors Ruby client:
# SERPAPI_LOCATION=Austin, Texas, United States
# SERPAPI_GOOGLE_DOMAIN=google.com

# SERPAPI_HL=en
# SERPAPI_GL=us

# Optional: comma-separated Google News queries when SERPAPI_Q is unset (default is six US/topic blends).
# SERPAPI_NEWS_QUERIES=United States top stories,technology news,business news

# Optional: title polish for /api/news (min/max headline length; junk titles dropped; duplicate titles collapsed).
# NEWS_TITLE_MIN_LENGTH=12
# NEWS_TITLE_MAX_LENGTH=280

# NewsAPI.org — used only if SERPAPI_API_KEY is unset.
# NEWSAPI_ORG_KEY=

# Optional alias:
# NEWSAPI_KEY=

# Full article text in the reader (optional): when the feed only has a short snippet, the server
# fetches readable text via Jina Reader (`r.jina.ai`), then falls back to basic HTML parsing.
# Set to 0 to disable outbound article fetches (also disables `/api/articles-read-meta` batch sizing).
# ARTICLE_READ_FETCH=0

# Optional: Jina Reader API key — improves `/api/article-read` and `/api/articles-read-meta`: https://jina.ai/
# JINA_API_KEY=

# Server-side feed cache TTL in seconds (600–1800). Default ≈ 900 (15 min). Bypass with `GET /api/news?refresh=1`.
# NEWS_FEED_CACHE_SECONDS=900

# Legacy: TheNewsAPI — used only if neither SerpAPI nor NewsAPI.org keys are set.
# NEWS_API_KEY=
# THENEWSAPI_API_TOKEN=

# Optional: first name in the header greeting (default: "there" → "Hi there,")
# NEXT_PUBLIC_GREETING_NAME=Nik

# Optional: override the OpenAI model for summarization (default: gpt-4o-mini)
# OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Optional: model for one-line reader subtitles (`/api/article-gist`; defaults to OPENAI_SUMMARY_MODEL or gpt-4o-mini)
# OPENAI_GIST_MODEL=gpt-4o-mini
